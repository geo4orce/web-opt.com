# run `php artisan config:clear` before editing
# run `php artisan config:cache` when finished (required in prod)
# Values: always use double quotes. Booleans: "1" (true) or "" (false).
# Note: `php artisan key:generate` does NOT work with quoted values — set APP_KEY manually.

APP_NAME="Web-Opt"
APP_ENV="local"
APP_DEBUG="1"
APP_KEY=""
APP_URL="https://web-opt.com"

LOG_CHANNEL="stack"
LOG_LEVEL="debug"

DB_CONNECTION="sqlite"

CACHE_DRIVER="file"
SESSION_DRIVER="file"
SESSION_LIFETIME="120"
QUEUE_DRIVER="sync"

MAIL_DRIVER="smtp"
MAIL_HOST=""
MAIL_PORT="587"
MAIL_USERNAME=""
MAIL_PASSWORD=""
MAIL_ENCRYPTION="tls"
MAIL_FROM_ADDRESS="contact@web-opt.com"
MAIL_FROM_NAME="Web-Opt"
MAIL_CONTACT="geo@web-opt.com"
