# cp .env.example .env — then fill in APP_KEY and MAIL_PASSWORD
# run `php artisan config:clear` before editing .env
# run `php artisan config:cache` when finished
# Values: always double-quoted. Booleans: "1" (true) or "" (false).
# Note: `php artisan key:generate` does NOT work with quoted values — set APP_KEY manually.

APP_NAME="Web-Opt"
APP_ENV="production" # set to "local" for development
APP_DEBUG="" # set to "1" for development
APP_KEY="" # run `php artisan key:generate` to generate (may need to remove the double quotes first, because it doesn't work with them)
APP_URL="https://web-opt.com" # no www

LOG_CHANNEL="stack"

# set it to "debug" or comment out this line for development
LOG_LEVEL="error"

DB_CONNECTION="sqlite"

CACHE_DRIVER="file"
SESSION_DRIVER="file"
SESSION_LIFETIME="120"
QUEUE_DRIVER="sync"

MAIL_DRIVER="smtp"
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USER="geo@web-opt.com" # this is both to and from
MAIL_PASSWORD="" # 16 characters app password from the google admin console
MAIL_ENCRYPTION="tls"
