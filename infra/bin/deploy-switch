#!/usr/bin/env bash
set -euo pipefail

# в”Ђв”Ђ Config в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SITES="gdice ezspell web-opt.com"
WWW="/var/www"
KEEP=5

# в”Ђв”Ђ Args в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SITE="${1:-}"
VERSION="${2:-}"

if [[ -z "$SITE" || -z "$VERSION" ]]; then
  echo "Usage: deploy-switch <site> <version>" >&2
  exit 1
fi

if ! echo "$SITES" | grep -qw "$SITE"; then
  echo "ERROR: Unknown site '$SITE'. Valid: $SITES" >&2
  exit 1
fi

if ! [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "ERROR: Invalid semver '$VERSION'" >&2
  exit 1
fi

SITE_DIR="$WWW/$SITE"
RELEASE_DIR="$SITE_DIR/releases/$VERSION"

# в”Ђв”Ђ Checks в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [[ ! -d "$RELEASE_DIR" ]] || [[ -z "$(ls -A "$RELEASE_DIR")" ]]; then
  echo "ERROR: Release dir missing or empty: $RELEASE_DIR" >&2
  exit 1
fi

CURRENT="$SITE_DIR/current"
if [[ -L "$CURRENT" ]]; then
  ACTIVE="$(basename "$(readlink "$CURRENT")")"
  if [[ "$ACTIVE" == "$VERSION" ]]; then
    echo "ERROR: $SITE $VERSION is already the active release. Bump version first." >&2
    exit 1
  fi
fi

# в”Ђв”Ђ Laravel shared files & permissions в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [[ "$SITE" == "web-opt.com" ]]; then
  SHARED="$SITE_DIR/shared"

  # Symlink .env
  ln -sfn "$SHARED/.env" "$RELEASE_DIR/.env"

  # Symlink storage
  rm -rf "$RELEASE_DIR/storage"
  ln -sfn "$SHARED/storage" "$RELEASE_DIR/storage"

  # Composer install
  cd "$RELEASE_DIR"
  composer install --no-dev --optimize-autoloader --no-interaction 2>&1

  # Artisan caches
  php artisan config:cache
  php artisan route:cache
  php artisan view:cache

fi

# в”Ђв”Ђ Normalize permissions в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
find "$RELEASE_DIR" -type d -exec chmod 755 {} +
find "$RELEASE_DIR" -type f -exec chmod 644 {} +

# в”Ђв”Ђ Laravel writable dirs (after normalize) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [[ "$SITE" == "web-opt.com" ]]; then
  chown -R deploy:www-data "$RELEASE_DIR/bootstrap/cache"
  chmod -R 2775 "$RELEASE_DIR/bootstrap/cache"
fi

# в”Ђв”Ђ Write version file в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [[ "$SITE" == "web-opt.com" ]]; then
  echo "$VERSION" > "$RELEASE_DIR/public/version.txt"
else
  echo "$VERSION" > "$RELEASE_DIR/version.txt"
fi

# в”Ђв”Ђ Switch symlink в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ln -sfn "releases/$VERSION" "$CURRENT"
echo "OK: $SITE switched to $VERSION"

# в”Ђв”Ђ Prune old releases в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cd "$SITE_DIR/releases"
mapfile -t RELEASES < <(ls -d [0-9]*.[0-9]*.[0-9]* 2>/dev/null | sort -t. -k1,1n -k2,2n -k3,3n)
COUNT=${#RELEASES[@]}

if (( COUNT > KEEP )); then
  PRUNE=$(( COUNT - KEEP ))
  for (( i=0; i<PRUNE; i++ )); do
    rm -rf "${RELEASES[$i]}"
  done
  echo "  Pruned $PRUNE old release(s), kept last $KEEP"
fi
