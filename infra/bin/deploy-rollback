#!/usr/bin/env bash
set -euo pipefail

# ── Config ──────────────────────────────────────────────
SITES="gdice ezspell web-opt.com"
WWW="/var/www"

# ── Args ────────────────────────────────────────────────
SITE="${1:-}"

if [[ -z "$SITE" ]]; then
  echo "Usage: deploy-rollback <site>" >&2
  exit 1
fi

if ! echo "$SITES" | grep -qw "$SITE"; then
  echo "ERROR: Unknown site '$SITE'. Valid: $SITES" >&2
  exit 1
fi

SITE_DIR="$WWW/$SITE"
CURRENT="$SITE_DIR/current"

# ── Find active release ─────────────────────────────────
if [[ ! -L "$CURRENT" ]]; then
  echo "ERROR: No active release for $SITE (no 'current' symlink)" >&2
  exit 1
fi

ACTIVE="$(basename "$(readlink "$CURRENT")")"

# ── List releases sorted by semver ──────────────────────
cd "$SITE_DIR/releases"
mapfile -t RELEASES < <(ls -d [0-9]*.[0-9]*.[0-9]* 2>/dev/null | sort -t. -k1,1n -k2,2n -k3,3n)

# ── Find active index ───────────────────────────────────
IDX=-1
for i in "${!RELEASES[@]}"; do
  if [[ "${RELEASES[$i]}" == "$ACTIVE" ]]; then
    IDX=$i
    break
  fi
done

if (( IDX < 0 )); then
  echo "ERROR: Active release '$ACTIVE' not found in releases/" >&2
  exit 1
fi

if (( IDX == 0 )); then
  echo "ERROR: No previous release to roll back to (active: $ACTIVE is the oldest)" >&2
  exit 1
fi

# ── Switch to previous release ──────────────────────────
PREV="${RELEASES[$((IDX - 1))]}"

# Re-link Laravel shared files if needed
if [[ "$SITE" == "web-opt.com" ]]; then
  SHARED="$SITE_DIR/shared"
  PREV_DIR="$SITE_DIR/releases/$PREV"
  ln -sfn "$SHARED/.env" "$PREV_DIR/.env"
  rm -rf "$PREV_DIR/storage"
  ln -sfn "$SHARED/storage" "$PREV_DIR/storage"
fi

ln -sfn "releases/$PREV" "$CURRENT"
echo "OK: $SITE rolled back from $ACTIVE to $PREV"
